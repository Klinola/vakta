# vakta auditd watch rules
# Install: sudo cp deploy/auditd/vakta.rules /etc/audit/rules.d/vakta.rules
#          sudo augenrules --load
#
# These rules generate the AUDIT_FIM events consumed by vakta's built-in
# detection rules. Without them, file-integrity events will not be produced.
# Coverage follows MITRE ATT&CK persistence and defense-evasion techniques.

# ── Rootkit / library injection ─────────────────────────────────────────────
-w /etc/ld.so.preload -p wa -k fim-preload
-w /etc/ld.so.conf -p wa -k fim-preload
-w /etc/ld.so.conf.d -p wa -k fim-preload

# ── Credential files ─────────────────────────────────────────────────────────
-w /etc/passwd -p wa -k fim-creds
-w /etc/shadow -p wa -k fim-creds
-w /etc/group -p wa -k fim-creds
-w /etc/gshadow -p wa -k fim-creds

# ── Privilege escalation paths ───────────────────────────────────────────────
-w /etc/sudoers -p wa -k fim-sudoers
-w /etc/sudoers.d -p wa -k fim-sudoers

# Capabilities / PAM
-w /etc/security -p wa -k fim-pam
-w /etc/pam.d -p wa -k fim-pam
-w /lib/security -p wa -k fim-pam
-w /lib64/security -p wa -k fim-pam

# ── SSH backdoors ─────────────────────────────────────────────────────────────
-w /root/.ssh -p wa -k fim-ssh
-w /home -p wa -k fim-ssh
-w /etc/ssh/sshd_config -p wa -k fim-ssh-config
-w /etc/ssh/sshd_config.d -p wa -k fim-ssh-config
# Host keys — replacement = MITM setup
-w /etc/ssh -p wa -k fim-ssh-config

# ── Systemd service persistence ───────────────────────────────────────────────
-w /etc/systemd/system -p wa -k fim-persistence
-w /usr/lib/systemd/system -p wa -k fim-persistence
-w /lib/systemd/system -p wa -k fim-persistence
# Systemd generators and dropin dirs
-w /etc/systemd/system.conf -p wa -k fim-persistence
-w /run/systemd/system -p wa -k fim-persistence

# ── Cron / at persistence ────────────────────────────────────────────────────
-w /etc/cron.d -p wa -k fim-persistence
-w /etc/cron.daily -p wa -k fim-persistence
-w /etc/cron.hourly -p wa -k fim-persistence
-w /etc/cron.weekly -p wa -k fim-persistence
-w /etc/cron.monthly -p wa -k fim-persistence
-w /etc/crontab -p wa -k fim-persistence
-w /var/spool/cron -p wa -k fim-persistence
-w /etc/at.allow -p wa -k fim-persistence
-w /etc/at.deny -p wa -k fim-persistence

# ── Shell profile / rc persistence ──────────────────────────────────────────
-w /etc/profile -p wa -k fim-persistence
-w /etc/profile.d -p wa -k fim-persistence
-w /etc/environment -p wa -k fim-persistence
-w /etc/bash.bashrc -p wa -k fim-persistence
-w /etc/zsh -p wa -k fim-persistence

# ── Init / boot persistence ───────────────────────────────────────────────────
-w /etc/rc.d -p wa -k fim-persistence
-w /etc/rc.local -p wa -k fim-persistence
-w /etc/init.d -p wa -k fim-persistence
-w /etc/initramfs-tools -p wa -k fim-persistence
# GRUB / bootloader tampering
-w /etc/grub.d -p wa -k fim-boot
-w /boot/grub/grub.cfg -p wa -k fim-boot
-w /etc/default/grub -p wa -k fim-boot

# ── Dynamic linker / library paths ───────────────────────────────────────────
-w /usr/lib -p wa -k fim-libs
-w /usr/lib64 -p wa -k fim-libs
-w /lib -p wa -k fim-libs
-w /lib64 -p wa -k fim-libs

# ── System binaries ───────────────────────────────────────────────────────────
-w /usr/bin -p wa -k fim-binaries
-w /usr/sbin -p wa -k fim-binaries
-w /bin -p wa -k fim-binaries
-w /sbin -p wa -k fim-binaries

# ── Kernel modules ────────────────────────────────────────────────────────────
-w /etc/modprobe.d -p wa -k fim-modules
-w /etc/modules -p wa -k fim-modules
-w /etc/modules-load.d -p wa -k fim-modules

# ── Network configuration ─────────────────────────────────────────────────────
# Hosts file tampering (DNS poisoning / redirect)
-w /etc/hosts -p wa -k fim-network
-w /etc/resolv.conf -p wa -k fim-network
-w /etc/hosts.allow -p wa -k fim-network
-w /etc/hosts.deny -p wa -k fim-network
# iptables / nftables persistence
-w /etc/iptables -p wa -k fim-network
-w /etc/nftables.conf -p wa -k fim-network

# ── Log tampering ─────────────────────────────────────────────────────────────
-w /var/log/wtmp -p wa -k fim-logs
-w /var/log/btmp -p wa -k fim-logs
-w /var/log/lastlog -p wa -k fim-logs
-w /var/log/auth.log -p wa -k fim-logs
-w /var/log/secure -p wa -k fim-logs
-w /var/log/syslog -p wa -k fim-logs

# ── Docker / container runtime ────────────────────────────────────────────────
-w /etc/docker -p wa -k fim-container
-w /etc/containerd -p wa -k fim-container
-w /var/lib/docker -p wa -k fim-container
